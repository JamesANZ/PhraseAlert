HUGGINGFACE_API_KEY=hf_...
AUTH_SECRET=generate-with-openssl-rand-base64-32
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Optional: direct (non-pooled) URL for migrations
# DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require
# AUTH_URL=http://localhost:3000

# Live web retrieval (Tavily Search + Extract)
TAVILY_API_KEY=tvly-...

# Google OAuth (required for sign-in)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Billing: Stripe (card subscription + prepaid)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PLUS_MONTHLY=price_...
# Optional: dedicated prepaid price; otherwise Checkout uses inline $9 price_data
# STRIPE_PRICE_ID_PLUS_PREPAID=price_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Billing: Helio / MoonPay Commerce (crypto prepaid)
HELIO_API_KEY=...
HELIO_SECRET_KEY=...
HELIO_PAYLINK_ID=...
HELIO_WEBHOOK_SECRET=...
# HELIO_API_BASE=https://api.hel.io/v1

# Expiry / downgrade emails + watch trigger alerts
RESEND_API_KEY=re_...
EMAIL_FROM="PhraseAlert <alerts@phrasealert.com>"

# CRON_SECRET=your-secret-for-scheduled-checks
